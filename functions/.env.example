# OCI API 인증 정보 (createUploadUrl 함수용)
# 실제 값은 functions/.env 에 저장 (커밋 금지)
# OCI 콘솔 > Identity > 내 프로필 > API Keys 에서 발급
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_KEY_FINGERPRINT=
OCI_REGION=ap-
OCI_NAMESPACE=
OCI_BUCKET=

# 프라이빗 키는 .env가 아니라 Secret Manager에 저장:
#   firebase functions:secrets:set OCI_PRIVATE_KEY
# (PEM 파일 내용 전체를 붙여넣기)
